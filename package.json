{
  "name": "chat-app-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/chat-api",
    "build": "npm run build -w apps/web && npm run build -w apps/chat-api",
    "start:web": "npm run start -w apps/web",
    "start:api": "npm run start -w apps/chat-api"
  }
}
